# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Content Copilot)
ANTHROPIC_API_KEY=

# Google Gemini (AI Art Generator)
GOOGLE_GEMINI_API_KEY=

# Gelato (Print-on-Demand)
GELATO_API_KEY=
GELATO_STORE_ID=

# Meta ad-spend sync (/api/cron/meta_spend_sync). Account id from Ads
# Manager ("act_" prefix optional); token needs the ads_read scope
# (falls back to META_GRAPH_ACCESS_TOKEN if that one carries it).
META_AD_ACCOUNT_ID=
META_ADS_ACCESS_TOKEN=

# Cron auth (/api/cron/[name]). Set CRON_SECRET in Vercel so its scheduler
# sends `Authorization: Bearer <CRON_SECRET>`; AGENT_TRIGGER_TOKEN authorizes
# manual/curl triggers. Without either, cron routes only run on localhost.
CRON_SECRET=
AGENT_TRIGGER_TOKEN=
