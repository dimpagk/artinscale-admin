# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Content Copilot)
ANTHROPIC_API_KEY=

# Google Gemini (AI Art Generator)
GOOGLE_GEMINI_API_KEY=

# Gelato (Print-on-Demand)
GELATO_API_KEY=
GELATO_STORE_ID=

# Cron auth (/api/cron/[name]). Set CRON_SECRET in Vercel so its scheduler
# sends `Authorization: Bearer <CRON_SECRET>`; AGENT_TRIGGER_TOKEN authorizes
# manual/curl triggers. Without either, cron routes only run on localhost.
CRON_SECRET=
AGENT_TRIGGER_TOKEN=
